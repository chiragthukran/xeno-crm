# PostgreSQL (Supabase)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Redis (Upstash)
REDIS_URL=redis://default:password@xxx.upstash.io:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# Shared secret for HMAC between CRM and channel stub
CHANNEL_HMAC_SECRET=super-secret-change-in-prod

# Channel stub URL (where CRM sends campaign jobs)
CHANNEL_STUB_URL=http://localhost:3001

# CRM receipt URL (where channel stub sends callbacks)
CRM_RECEIPT_URL=http://localhost:3000

# Service ports
CRM_API_PORT=3000
CHANNEL_STUB_PORT=3001
