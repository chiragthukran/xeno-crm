{
  "name": "xeno-crm",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "tsx $SERVICE_ENTRY",
    "db:push": "pnpm --filter @xeno/db db:push",
    "db:seed": "pnpm --filter @xeno/db db:seed",
    "db:migrate": "pnpm --filter @xeno/db db:migrate"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
